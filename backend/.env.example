# ─────────────────────────────────────────────────────────────────────────────
# Illuminate Studios — backend environment template
# Copy to .env for local dev, or set these as service Variables on Railway.
# Required vars must be present or the app will report a clear error on first use.
# ─────────────────────────────────────────────────────────────────────────────

# ---- Database (REQUIRED) ----
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=illuminate_studios

# ---- Auth (REQUIRED) ----
# Generate: python3 -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=
ADMIN_EMAIL=photographer@illuminatestudios.com.au
ADMIN_PASSWORD=

# ---- CORS ----
# Comma-separated origins in production (enables cross-site cookies).
# "*" is a dev-only fallback and disables credentialed requests.
CORS_ORIGINS=https://app.illuminatestudios.com.au

# ---- LLM / Luma (REQUIRED for the Luma chat assistant) ----
OPENAI_API_KEY=
LUMA_MODEL=gpt-4.1

# ---- Email (Resend) ----
RESEND_API_KEY=
MAIL_FROM_NAME=Illuminate Studios
MAIL_FROM_INVOICES=accounts@invoicing.illuminatestudios.com.au
MAIL_FROM_NOTIFICATIONS=donotreply@notifications.illuminatestudios.com.au
ADMIN_NOTIFICATION_EMAIL=photographer@illuminatestudios.com.au

# ---- PayID / bank details (shown on invoices) ----
PAYID_IDENTIFIER=accounts@illuminatestudios.com.au
PAYID_BUSINESS_NAME=Illuminate Studios
INVOICE_BSB=
INVOICE_ACCOUNT_NUMBER=
INVOICE_ACCOUNT_NAME=Illuminate Studios Pty Ltd
INVOICE_REFERENCE_PREFIX=INV

# ---- Public URL ----
APP_PUBLIC_URL=https://app.illuminatestudios.com.au

# ---- Object storage (OPTIONAL) ----
# If S3_BUCKET is set, S3/R2 storage is used; otherwise blobs are stored in Mongo.
# S3_BUCKET=illuminate-studios-photos
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
