# ─────────────────────────────────────────────────────────────────────────────
# Illuminate Studios — backend environment template
# Copy to .env for local dev, or set these as service Variables on Railway.
# Required vars must be present or the app will report a clear error on first use.
# ─────────────────────────────────────────────────────────────────────────────

# ---- Database (REQUIRED) ----
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=illuminate_studios

# ---- Environment ----
# "production" disables dev-only conveniences (e.g. the seeded test client).
# Anything else (development/staging/test) enables them.
ENVIRONMENT=development

# ---- Auth (REQUIRED) ----
# Generate each: python3 -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=                      # admin/staff JWT access-token signing (HS256)
CLIENT_SESSION_SECRET=           # peppers the at-rest hash of session/magic-link/invite/gallery tokens
ADMIN_EMAIL=photographer@illuminatestudios.com.au
ADMIN_PASSWORD=

# ---- Owner bootstrap (OPTIONAL) ----
# If both are set, a role:"owner" account is seeded on startup (idempotent).
# The owner can invite admin/editor staff (handoff brief §6). The ADMIN_EMAIL
# account above is seeded as role:"admin" and is unaffected.
# OWNER_EMAIL=owner@illuminatestudios.com.au
# OWNER_PASSWORD=

# ---- Cloudflare Worker (REQUIRED for gallery media delivery — brief §4) ----
# Shared between this backend and the media Worker. Signs the 4h gallery_token.
CLOUDFLARE_WORKER_SHARED_SECRET=

# ---- CORS ----
# Comma-separated origins in production (enables cross-site cookies).
# "*" is a dev-only fallback and disables credentialed requests.
CORS_ORIGINS=https://app.illuminatestudios.com.au
# Optional regex for dynamic preview origins (example for Railway preview apps):
# CORS_ORIGIN_REGEX=^https://[a-z0-9-]+\\.up\\.railway\\.app$

# ---- LLM / Luma (REQUIRED for the Luma chat assistant) ----
OPENAI_API_KEY=
LUMA_MODEL=gpt-4.1

# ---- Email (Resend) ----
RESEND_API_KEY=
MAIL_FROM_NAME=Illuminate Studios
MAIL_FROM_INVOICES=accounts@invoicing.illuminatestudios.com.au
MAIL_FROM_NOTIFICATIONS=donotreply@notifications.illuminatestudios.com.au
ADMIN_NOTIFICATION_EMAIL=photographer@illuminatestudios.com.au

# ---- PayID / bank details (shown on invoices) ----
PAYID_IDENTIFIER=accounts@illuminatestudios.com.au
PAYID_BUSINESS_NAME=Illuminate Studios
INVOICE_BSB=
INVOICE_ACCOUNT_NUMBER=
INVOICE_ACCOUNT_NAME=Illuminate Studios Pty Ltd
INVOICE_REFERENCE_PREFIX=INV

# ---- Public URL ----
APP_PUBLIC_URL=https://app.illuminatestudios.com.au

# ---- Object storage (OPTIONAL) ----
# If S3_BUCKET is set, S3/R2 storage is used; otherwise blobs are stored in Mongo.
# S3_BUCKET=illuminate-studios-photos
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
#
# NOTE (Priority 3 — Storage foundation): the handoff brief §9 mandates renaming
# these to MONGODB_URI and R2_* (R2_ACCOUNT_ID, R2_ACCESS_KEY_ID,
# R2_SECRET_ACCESS_KEY, R2_ENDPOINT_URL, R2_BUCKET_DERIVATIVES,
# R2_BUCKET_ORIGINALS, R2_CUSTOM_DOMAIN). Priority 2 deliberately does NOT rename
# MONGO_URL / DB_NAME / S3_* — the rename + dual R2 buckets are done when the R2
# adapter is built in Priority 3, so this auth work introduces no env churn.
